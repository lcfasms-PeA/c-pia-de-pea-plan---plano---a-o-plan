# ============================================================================
# PeA-Plan Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in the actual values for your environment
# DO NOT commit .env to version control - it contains sensitive credentials
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================
# MySQL connection string
# Format: mysql://username:password@host:port/database_name
# Example: mysql://root:senha123@localhost:3306/pea_plan_dev
DATABASE_URL=mysql://user:password@localhost:3306/pea_plan

# ============================================================================
# AUTHENTICATION (REQUIRED)
# ============================================================================
# Secret key for JWT token signing - use a long random string (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-this-in-production-min-32-chars

# Application ID for OAuth and internal identification
VITE_APP_ID=pea-plan-app-id

# ============================================================================
# MANUS OAUTH INTEGRATION (REQUIRED)
# ============================================================================
# URL to the Manus/Forge OAuth server
# Example: https://manus.example.com or http://localhost:8080
OAUTH_SERVER_URL=http://localhost:8080

# Your organization/owner ID in Manus system
# Contact Manus support to get this ID
OWNER_OPEN_ID=your-manus-owner-id

# ============================================================================
# LLM / AI INTEGRATION (REQUIRED for IA features)
# ============================================================================
# URL to the Forge API server (for LLM requests)
# Example: https://forge.example.com/api or http://localhost:5000/api
BUILT_IN_FORGE_API_URL=http://localhost:5000/api

# API key for authenticating with Forge
# This key should have permissions for text generation
BUILT_IN_FORGE_API_KEY=your-api-key-here

# LLM model to use (optional, defaults to gemini-2.5-flash)
# Options: gemini-2.5-flash, gpt-4, claude-3, etc.
# LLM_MODEL=gemini-2.5-flash

# ============================================================================
# SERVER CONFIGURATION (OPTIONAL - has sensible defaults)
# ============================================================================
# Port to run the server on (default: 3000)
# PORT=3000

# Environment: development or production (default: development)
# NODE_ENV=development

# ============================================================================
# OPTIONAL: AWS S3 for file uploads (if using file storage)
# ============================================================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=pea-plan-uploads

# ============================================================================
# OPTIONAL: Email configuration (for notifications)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ============================================================================
# NOTES
# ============================================================================
# 1. All REQUIRED variables must be set before starting the application
# 2. The app will fail to start if any REQUIRED variable is missing
# 3. Use different .env files for development, staging, and production
# 4. Never commit .env to version control
# 5. For local development without OAuth/Forge, use mock values and update later
# 6. Database migrations run automatically on startup (see pnpm run db:push)
